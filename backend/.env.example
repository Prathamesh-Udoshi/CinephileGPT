# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cinephile_db

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Security & Auth Configuration
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Vector DB Configuration (Local file storage)
QDRANT_PATH=./qdrant_db

# Embedding Configuration
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Redis Caching Settings
ENABLE_REDIS_CACHE=True
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# TTL Settings (in seconds)
REDIS_TTL_RECOMMENDATIONS=3600
REDIS_TTL_SESSIONS=1800

# Cost Savings calculation constant
API_COST_SAVINGS_PER_HIT=0.005

